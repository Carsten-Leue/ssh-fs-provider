<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules (Android 12+ / API 31+).

    Exclude the entire app private-data directory from both cloud backup and
    device-to-device transfer.  SSH private keys and the encrypted config must
    never leave the device via Android's backup or migration mechanisms.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="." />
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="external" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="external" path="." />
    </device-transfer>
</data-extraction-rules>
