<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- SSH connections require internet access -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!--
        Declare that the app uses network connectivity but does not require
        any specific hardware (Wi-Fi or mobile data both work).
    -->
    <uses-feature android:name="android.hardware.wifi" android:required="false" />

    <application
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:description="@string/app_description"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SshFsProvider"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- Launcher: config import / management UI -->
        <activity
            android:name=".ConfigImportActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:description="@string/activity_import_description"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Help screen activity -->
        <activity
            android:name=".HelpActivity"
            android:exported="false"
            android:label="@string/help_title"
            android:parentActivityName=".ConfigImportActivity" />

        <!--
            SAF DocumentsProvider – exposes SFTP file systems to all Android apps
            via the Storage Access Framework document picker.

            android:permission="android.permission.MANAGE_DOCUMENTS" restricts
            direct provider access to the system document picker only, which is
            the correct security model for a DocumentsProvider.
        -->
        <provider
            android:name=".SshDocumentsProvider"
            android:authorities="io.github.carstenleue.sshfsprovider.documents"
            android:exported="true"
            android:grantUriPermissions="true"
            android:label="@string/provider_label"
            android:permission="android.permission.MANAGE_DOCUMENTS">
            <intent-filter>
                <action android:name="android.content.action.DOCUMENTS_PROVIDER" />
            </intent-filter>
        </provider>

    </application>

</manifest>
